# Database connection
DATABASE_URL=your_neon_database_url_here

# Environment
NODE_ENV=development

# Set to true if running in Replit
REPLIT=false

# Server configuration
PORT=5000

# If you experience WebSocket connection issues in local development,
# try enabling direct connections by setting this to false
USE_WEBSOCKET=true

# Session secret (generate a unique string for this)
SESSION_SECRET=your_secret_key_here

# API Keys
OPENAI_API_KEY=your_openai_api_key_here